<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.EchoMind"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:targetApi="31">

        <activity
            android:name=".LoginActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".MainActivity"
            android:exported="false" />

        <activity
            android:name=".RegisterActivity"
            android:exported="false"
            android:label="회원가입" />

        <activity
            android:name=".AnalysisActivity"
            android:exported="false"
            android:label="분석하기" />

        <activity
            android:name=".ResultActivity"
            android:exported="false"
            android:label="분석 결과" />

        <activity
            android:name=".MatchActivity"
            android:exported="false"
            android:label="매칭 찾기" />

        <activity
            android:name=".InboxActivity"
            android:exported="false"
            android:label="인박스" />

        <activity
            android:name=".ChatActivity"
            android:exported="false"
            android:label="채팅" />

        <activity
            android:name=".GroupLoungeActivity"
            android:exported="false"
            android:label="그룹 라운지" />

        <activity
            android:name=".GroupChatActivity"
            android:exported="false"
            android:label="그룹 채팅" />

        <activity
            android:name=".GroupCreateActivity"
            android:exported="false"
            android:label="새 그룹 만들기" />

        <activity
            android:name=".HistoryActivity"
            android:exported="false" />

        <!-- [추가] 매칭 상대방 성격 분석 상세 화면 -->
        <activity
            android:name=".MatchDetailActivity"
            android:exported="false"
            android:label="상대방 분석 상세" />

    </application>

</manifest>
