<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card_bg"
    app:strokeWidth="1dp"
    app:strokeColor="@color/border">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- 1. 왼쪽: 프로필 이니셜 -->
            <TextView
                android:id="@+id/tvProfileInitial"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/bg_status_badge"
                android:backgroundTint="#15F43F5E"
                android:gravity="center"
                android:text="정"
                android:textColor="#F43F5E"
                android:textSize="18sp"
                android:fontFamily="sans-serif-black"
                android:layout_alignParentStart="true" />

            <!-- 2. 오른쪽: 취소 버튼 -->
            <TextView
                android:id="@+id/btnRequestUnmatch"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="4dp"
                android:text="취소"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="4dp"
                android:clickable="true"
                android:focusable="true" />

            <!-- 3. 중앙: 이름 및 버튼 그룹 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_toEndOf="@id/tvProfileInitial"
                android:layout_toStartOf="@id/btnRequestUnmatch"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="4dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvFriendName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="사용자 이름"
                        android:textSize="18sp"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/text_primary"
                        android:maxLines="1"
                        android:ellipsize="end" />

                    <!-- 보기 버튼 -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnViewDetail"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:minWidth="54dp"
                        android:layout_marginStart="8dp"
                        android:text="보기"
                        android:textSize="11sp"
                        android:paddingVertical="0dp"
                        android:paddingHorizontal="8dp"
                        app:strokeColor="@color/border"
                        app:cornerRadius="8dp"
                        android:textColor="@color/primary" />

                    <!-- 채팅 버튼 영역 -->
                    <FrameLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnChat"
                            android:layout_width="wrap_content"
                            android:layout_height="32dp"
                            android:minWidth="64dp"
                            android:text="채팅"
                            android:textSize="11sp"
                            android:paddingVertical="0dp"
                            android:paddingHorizontal="8dp"
                            app:backgroundTint="@color/primary"
                            app:cornerRadius="8dp"
                            android:insetTop="0dp"
                            android:insetBottom="0dp" />

                        <!-- 안 읽은 메시지 배지 -->
                        <TextView
                            android:id="@+id/tvUnreadBadge"
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_gravity="top|end"
                            android:layout_marginTop="-4dp"
                            android:layout_marginEnd="-4dp"
                            android:background="@drawable/bg_unread_badge"
                            android:gravity="center"
                            android:text="3"
                            android:textColor="@color/white"
                            android:textSize="9sp"
                            android:textStyle="bold"
                            android:visibility="visible" />
                    </FrameLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/tvLastMessage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="최근 대화 내용..."
                    android:textColor="@color/text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <TextView
                    android:id="@+id/tvMatchDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="2026-03-26"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>
        </RelativeLayout>

        <!-- [수정] 내가 매칭 해제를 요청했을 때 (대기 상태) -->
        <LinearLayout
            android:id="@+id/layoutMyUnmatchRequest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="#05000000"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상대방의 매칭 취소 수락을 기다리고 있습니다."
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWithdrawUnmatch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="요청 철회"
                app:cornerRadius="12dp" />
        </LinearLayout>

        <!-- [추가] 상대방이 매칭 해제를 요청했을 때 -->
        <LinearLayout
            android:id="@+id/layoutPartnerUnmatchRequest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:padding="16dp"
            android:background="@drawable/bg_status_badge"
            android:backgroundTint="#10F43F5E"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="상대방이 매칭 취소를 요청했습니다."
                android:textColor="#F43F5E"
                android:textStyle="bold"
                android:textSize="12sp" />
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp">
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnmatchAccept"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="수락 (해제)"
                    android:layout_marginEnd="8dp"
                    app:backgroundTint="#F43F5E"
                    app:cornerRadius="12dp" />
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnUnmatchReject"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="거절"
                    app:strokeColor="@color/border"
                    app:cornerRadius="12dp" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
